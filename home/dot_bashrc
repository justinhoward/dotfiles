# shellcheck shell=bash
# ~/.bashrc — interactive bash only.
# Non-login interactive bash does not read ~/.profile, so load env here too —
# unless a login ~/.bash_profile already sourced it via ~/.profile in this same
# process (it sets _bashrc_env_loaded to say so). env.sh itself is left fully
# re-sourceable; this only skips the bash login double-load.
if [ -z "${_bashrc_env_loaded-}" ] && [ -r "$HOME/.config/sh/env.sh" ]; then
  . "$HOME/.config/sh/env.sh"
fi
unset _bashrc_env_loaded

# Real interactive terminals only — gate on a TTY so an IDE shell-env resolver
# (interactive but non-tty) keeps the static shims dir from env.sh in front,
# resolving tool versions per-directory. See ~/.zshrc for the full rationale.
if command -v mise >/dev/null 2>&1 && { [ -t 1 ] || [ -t 2 ]; }; then
  eval "$(mise activate bash)"
fi
command -v zoxide   >/dev/null 2>&1 && eval "$(zoxide init bash)"
command -v fzf      >/dev/null 2>&1 && eval "$(fzf --bash)"
command -v gpg      >/dev/null 2>&1 && { GPG_TTY="$(tty)"; export GPG_TTY; }  # zsh sets this in ~/.zshrc

# Prompt: zsh gets powerlevel10k; bash stays simple and dependency-free by
# design (mirrors the old zsh-fancy / bash-basic split). blue user@host, cyan cwd.
PS1='\[\e[1;34m\]\u@\h\[\e[0m\] \[\e[36m\]\w\[\e[0m\] \$ '

# Shared, shell-agnostic aliases / snippets (same files zsh sources).
for _rc in "$HOME"/.config/sh/rc.d/*.sh; do
  [ -r "$_rc" ] && . "$_rc"
done
unset _rc
