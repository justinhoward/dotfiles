# ~/.config/git/config — git reads this natively (XDG). Identity is templated
# per-machine by chezmoi, so no ~/.gitconfig include-path split is needed.

[user]
	name = {{ .name }}
	email = {{ .email }}
{{- if .signingkey }}
	signingkey = {{ .signingkey }}
{{- end }}

[core]
	pager = delta

[interactive]
	# Colorize `git add -p` / `git add -i` hunks with delta too (the gip/giR/gcO
	# patch-staging aliases). --color-only keeps delta's decorations out of the
	# text git feeds back to the patch parser.
	diffFilter = delta --color-only

[init]
	# preserve the historical default branch name (git's own default is `main`).
	defaultBranch = master

[color "diff"]
	frag = magenta
	meta = yellow
	new = green
	old = red

# Log formats live here now (previously injected by prezto + shell variables).
[pretty]
	dot-medium = "format:%C(bold)Commit:%C(reset) %C(green)%h%C(red)%d%n%C(bold)Author:%C(reset) %C(cyan)%an <%ae>%n%C(bold)Date:%C(reset)   %C(blue)%ai (%ar)%C(reset)%n%+B"
	dot-oneline = "format:%C(green)%h%C(reset) %s%C(red)%d%C(reset)"
	dot-brief = "format:%C(green)%h%C(reset) %s%n%C(blue)(%ar by %an)%C(red)%d%C(reset)"
	dot-cherry = "format:%m %C(green)%h%C(reset) %s%C(red)%d%C(reset)"

# Log aliases (git l/ls/lo/lg/lb/lp/lf/ld); the g* shell aliases wrap these.
[alias]
	l = log --topo-order --pretty=dot-medium
	ls = log --topo-order --stat --pretty=dot-medium
	lo = log --topo-order --pretty=dot-oneline
	lg = log --topo-order --graph --pretty=dot-oneline
	lb = log --topo-order --pretty=dot-brief
	lp = log --topo-order --stat --patch --full-diff --pretty=dot-medium
	lf = log --topo-order --name-status --pretty=dot-medium
	ld = log --left-right --cherry-mark --no-merges --topo-order --pretty=dot-cherry

[merge]
	tool = nvimdiff
	# zdiff3 (git 2.35+) is a cleaner successor to diff3 conflict markers.
	conflictstyle = zdiff3
	prompt = false

[mergetool]
	keepBackup = false

[mergetool "nvimdiff"]
	cmd = nvim -d $BASE $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'

[diff]
	tool = nvimdiff
	colorMoved = default
	# don't flag pure re-indentation as a moved block (pairs with colorMoved).
	colorMovedWS = allow-indentation-change
	# histogram produces more readable diffs than the default myers algorithm.
	algorithm = histogram

[difftool]
	prompt = false

[difftool "nvimdiff"]
	cmd = nvim -d $LOCAL $MERGED

[delta]
	line-numbers = true
	# n / N jump between diff sections (files, hunks).
	navigate = true
	# clickable commit hashes and file paths in terminals that support OSC 8.
	hyperlinks = true
	# No hardcoded plus/minus colors: delta queries the terminal background and
	# picks matching light/dark defaults on every run, so diffs track the OS
	# light/dark switch (kitty's *-theme.auto.conf) the same way nvim and bat do.
	# Pin with `dark = true` / `light = true` if a terminal won't answer the query.

[commit]
	gpgSign = true

[tag]
	gpgSign = true
	# semantic (version-aware) ordering, matching the gt/gT aliases.
	sort = version:refname

# --- Modern defaults -------------------------------------------------------
[push]
	# `git push` on a new branch auto-creates its upstream (git 2.37+).
	autoSetupRemote = true

[fetch]
	# drop local remote-tracking refs for branches deleted upstream.
	prune = true

[pull]
	# refuse non-fast-forward pulls; rebase/merge must be explicit.
	ff = only

[rebase]
	# auto-order fixup!/squash! commits when rebasing (pairs with the gcf amend
	# workflow + `git commit --fixup`).
	autosquash = true
	# stash a dirty worktree around a rebase and restore it after (gfra did this
	# per-pull; make it the default for gr/grd/gri too).
	autostash = true
	# when a rebase rewrites a branch that others are stacked on, move their tips
	# too — keeps stacked branches consistent (git 2.38+).
	updateRefs = true

[rerere]
	# reuse recorded conflict resolutions across repeated rebases/merges.
	enabled = true

[column]
	ui = auto

[branch]
	# most-recently-committed branches first in `git branch`.
	sort = -committerdate
