{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@rama_nigg/open-cursor@latest"],
  "lsp": true,
  "permission": {
    "edit": "allow",
    "external_directory": {
      "*": "ask"
    },
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "which *": "allow",
      "wc *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "fd *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git remote": "allow",
      "git remote *": "allow",
      "git blame *": "allow",
      "git stash list": "allow",
      "git rev-parse *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git fetch": "allow",
      "git fetch *": "allow",
      "sudo": "deny",
      "sudo *": "deny",
      "rm -rf *": "deny",
      "git push --force*": "deny",
      "git reset --hard*": "deny"
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 600000
      }
    }
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "circleci": {
      "type": "local",
      "command": ["/opt/homebrew/bin/circleci", "mcp", "start"],
      "enabled": true
    }
  }
}
