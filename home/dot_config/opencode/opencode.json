{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@rama_nigg/open-cursor@latest", "opencode-codebase-index"],
  "lsp": true,
  "permission": {
    "edit": "allow",
    "external_directory": {
      "*": "ask"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "which *": "allow",
      "wc *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "fd *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git remote": "allow",
      "git remote *": "allow",
      "git blame *": "allow",
      "git stash list": "allow",
      "git rev-parse *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git fetch": "allow",
      "git fetch *": "allow",
      "sudo": "deny",
      "sudo *": "deny",
      "rm -rf *": "deny",
      "git push --force*": "deny",
      "git reset --hard*": "deny"
    },
    "atlassian_*": "allow",
    "atlassian_add*": "ask",
    "atlassian_create*": "ask",
    "atlassian_edit*": "ask",
    "atlassian_update*": "ask",
    "atlassian_transition*": "ask",
    "circleci_*_list": "allow",
    "circleci_*list-categories": "allow",
    "circleci_*_get": "allow",
    "circleci_*_validate": "allow",
    "circleci_*_process": "allow",
    "circleci_*_pack": "allow",
    "circleci_*_source": "allow",
    "circleci_*_diff": "allow",
    "circleci_*_fetch": "allow",
    "circleci_*_logs": "allow",
    "circleci_*_decide": "allow",
    "circleci_*_me": "allow",
    "circleci_*_id": "allow",
    "circleci_*_runs": "allow",
    "circleci_*_version": "allow",
    "circleci_*artifact": "allow",
    "circleci_*_task": "allow",
    "circleci_*_output": "allow",
    "circleci_*_output_get": "allow",
    "circleci_*_output_list": "allow"
  },
  "provider": {
    "github-copilot": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 600000
      }
    },
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "psai"
      }
    },
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "circleci": {
      "type": "local",
      "command": ["/opt/homebrew/bin/circleci", "mcp", "start"],
      "enabled": true
    }
  }
}
