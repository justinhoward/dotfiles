# ~/.config/sh/env.sh — shared environment for ALL shells.
# Sourced by ~/.zshenv (zsh, always) and ~/.profile / ~/.bashrc (bash, sh).
#
# Rules: POSIX only, no interactive assumptions, and no subprocess forks in
# the hot path (this runs for every script and the GUI env resolver).

: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
export XDG_CONFIG_HOME XDG_DATA_HOME XDG_CACHE_HOME

# --- PATH ------------------------------------------------------------------
# Prepend helpers: add a dir only if it exists and isn't already present, so
# re-sourcing this file (every zsh runs ~/.zshenv, incl. nested/subshells)
# keeps PATH/MANPATH stable and duplicate-free. Fork-free (POSIX builtins).
#
# When _PATH_REASSERT is set, an already-present dir is force-moved back to the
# front instead of being left in place. Login shells re-source this file from
# ~/.zprofile *after* macOS /etc/zprofile has run path_helper, which prepends
# the stock system dirs (/usr/bin, …) and shoves our mise shims / Homebrew bins
# behind system Ruby et al. Reasserting restores the intended precedence.
# Iterates via ${%%:*}/${#*:} parameter expansion rather than `for x in $PATH`,
# because zsh does not field-split unquoted expansions (this file is sourced by
# zsh and bash/sh alike) — a `for` loop would see PATH as one word and remove
# nothing, leaving stale duplicates behind.
_path_rm() {
  case ":$PATH:" in *":$1:"*) ;; *) return 0 ;; esac
  _rm_out=""; _rm_rest="$PATH"
  while [ -n "$_rm_rest" ]; do
    _rm_dir="${_rm_rest%%:*}"
    case "$_rm_rest" in *:*) _rm_rest="${_rm_rest#*:}" ;; *) _rm_rest="" ;; esac
    [ "$_rm_dir" = "$1" ] && continue
    _rm_out="${_rm_out:+$_rm_out:}$_rm_dir"
  done
  PATH="$_rm_out"
}
_pathpre() {
  [ -d "$1" ] || return 0
  case ":$PATH:" in
    *":$1:"*) [ -n "${_PATH_REASSERT-}" ] && { _path_rm "$1"; PATH="$1:$PATH"; } ;;
    *) PATH="$1:$PATH" ;;
  esac
}
# Only invoked from the macOS block below; on non-macOS renders it is defined
# for symmetry (and unset at the end), so shellcheck sees it as never called.
# shellcheck disable=SC2317,SC2329
_manpre()  { case ":${MANPATH-}:" in *":$1:"*) ;; *) [ -d "$1" ] && MANPATH="$1:${MANPATH-}" ;; esac; }

{{- if eq .chezmoi.os "darwin" }}
# Homebrew prefix is baked in at `chezmoi apply` time — no runtime
# `eval "$(brew shellenv)"` fork on every shell.
export HOMEBREW_PREFIX="/opt/homebrew"
_pathpre "$HOMEBREW_PREFIX/sbin"
_pathpre "$HOMEBREW_PREFIX/bin"
_manpre  "$HOMEBREW_PREFIX/share/man"
# GNU coreutils/findutils/grep/sed/tar/getopt ahead of the BSD equivalents.
# Each gnubin/gnuman dir is probed at apply time (chezmoi `stat`) and only
# emitted when present — no `brew --prefix` fork.
{{- range $pkg := list "coreutils" "findutils" "grep" "gnu-sed" "gnu-tar" "gnu-getopt" }}
{{-   $gnubin := printf "/opt/homebrew/opt/%s/libexec/gnubin" $pkg }}
{{-   $gnuman := printf "/opt/homebrew/opt/%s/libexec/gnuman" $pkg }}
{{-   if stat $gnubin }}
_pathpre "{{ $gnubin }}"
{{-   end }}
{{-   if stat $gnuman }}
_manpre  "{{ $gnuman }}"
{{-   end }}
{{- end }}
{{- end }}

# mise shims: a STATIC directory on PATH so non-interactive shells and
# GUI-spawned subprocesses (linters, LSPs, MCP servers) resolve the correct
# tool versions without a shell hook. Interactive shells later swap this for
# `mise activate` (PATH mode) in ~/.zshrc.
_pathpre "$XDG_DATA_HOME/mise/shims"

_pathpre "$XDG_CONFIG_HOME/composer/vendor/bin"
_pathpre "$HOME/.cargo/bin"
_pathpre "$HOME/.swiftly/bin"      # swift toolchain (swiftly)
_pathpre "$HOME/.local/bin"
_pathpre "$HOME/bin"
export PATH MANPATH
unset -f _pathpre _manpre _path_rm
unset _rm_out _rm_rest _rm_dir

# --- Locale ----------------------------------------------------------------
[ -z "${LANG-}" ] && export LANG="en_US.UTF-8"

# --- umask -----------------------------------------------------------------
umask 0002

# --- Editor / pager --------------------------------------------------------
if command -v nvim >/dev/null 2>&1; then
  EDITOR="nvim"
else
  EDITOR="vim"
fi
export EDITOR
export VISUAL="$EDITOR"
export PAGER="less"
export LESS="-g -i -M -R -S -w -z-4"

# Colorized man pages via bat, when available.
if command -v bat >/dev/null 2>&1; then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
  export MANROFFOPT="-c"
fi

# --- opencode --------------------------------------------------------------
# Keep the TUI's mouse capture (click-to-focus, scroll) but stop it from
# auto-copying highlighted text on mouse-up — selection then just highlights and
# you copy deliberately (keybind / right-click) instead of clobbering the
# clipboard. Read only by the interactive TUI; a no-op for scripts and the GUI
# env resolver. Parsed truthy on "true"/"1". A future opencode build folds this
# into `copy_on_select: false` in tui.json; 1.17.x exposes only the env flag.
export OPENCODE_EXPERIMENTAL_DISABLE_COPY_ON_SELECT=true
{{- if eq .chezmoi.os "linux" }}

# --- Linux desktop (X11 / window managers) ---------------------------------
# Set here (not in an interactive rc file) so GUI apps launched from the X
# session inherit these via ~/.profile.
#
# BROWSER: first installed GUI browser, honored by xdg-open and many CLIs.
# `command -v` is a POSIX builtin (no fork); the loop stops at the first hit.
for _b in firefox google-chrome google-chrome-stable chromium; do
  command -v "$_b" >/dev/null 2>&1 && { export BROWSER="$_b"; break; }
done
unset _b

# ssh-agent user service (~/.config/systemd/user/ssh-agent.service) exposes its
# socket here; point SSH_AUTH_SOCK at it for every process. Guarded on
# XDG_RUNTIME_DIR so a non-systemd session doesn't get a broken socket path.
[ -n "${XDG_RUNTIME_DIR-}" ] && export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
{{- end }}
