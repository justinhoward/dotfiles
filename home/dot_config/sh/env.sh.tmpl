# ~/.config/sh/env.sh — shared environment for ALL shells.
# Sourced by ~/.zshenv (zsh, always) and ~/.profile / ~/.bashrc (bash, sh).
#
# Rules: POSIX only, no interactive assumptions, and no subprocess forks in
# the hot path (this runs for every script and the GUI env resolver).

: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
export XDG_CONFIG_HOME XDG_DATA_HOME XDG_CACHE_HOME

# --- PATH ------------------------------------------------------------------
# Prepend helpers: add a dir only if it exists and isn't already present, so
# re-sourcing this file (every zsh runs ~/.zshenv, incl. nested/subshells)
# keeps PATH/MANPATH stable and duplicate-free. Fork-free (POSIX builtins).
_pathpre() { case ":$PATH:" in *":$1:"*) ;; *) [ -d "$1" ] && PATH="$1:$PATH" ;; esac; }
_manpre()  { case ":${MANPATH-}:" in *":$1:"*) ;; *) [ -d "$1" ] && MANPATH="$1:${MANPATH-}" ;; esac; }

{{- if eq .chezmoi.os "darwin" }}
# Homebrew prefix is baked in at `chezmoi apply` time — no runtime
# `eval "$(brew shellenv)"` fork on every shell.
export HOMEBREW_PREFIX="/opt/homebrew"
_pathpre "$HOMEBREW_PREFIX/sbin"
_pathpre "$HOMEBREW_PREFIX/bin"
_manpre  "$HOMEBREW_PREFIX/share/man"
# GNU coreutils/findutils/grep/sed/tar/getopt ahead of the BSD equivalents.
# Each gnubin/gnuman dir is probed at apply time (chezmoi `stat`) and only
# emitted when present — no `brew --prefix` fork.
{{- range $pkg := list "coreutils" "findutils" "grep" "gnu-sed" "gnu-tar" "gnu-getopt" }}
{{-   $gnubin := printf "/opt/homebrew/opt/%s/libexec/gnubin" $pkg }}
{{-   $gnuman := printf "/opt/homebrew/opt/%s/libexec/gnuman" $pkg }}
{{-   if stat $gnubin }}
_pathpre "{{ $gnubin }}"
{{-   end }}
{{-   if stat $gnuman }}
_manpre  "{{ $gnuman }}"
{{-   end }}
{{- end }}
{{- end }}

# mise shims: a STATIC directory on PATH so non-interactive shells and
# GUI-spawned subprocesses (linters, LSPs, MCP servers) resolve the correct
# tool versions without a shell hook. Interactive shells later swap this for
# `mise activate` (PATH mode) in ~/.zshrc.
_pathpre "$XDG_DATA_HOME/mise/shims"

_pathpre "$XDG_CONFIG_HOME/composer/vendor/bin"
_pathpre "$HOME/.cargo/bin"
_pathpre "$HOME/.local/bin"
_pathpre "$HOME/bin"
export PATH MANPATH
unset -f _pathpre _manpre

# --- Locale ----------------------------------------------------------------
[ -z "${LANG-}" ] && export LANG="en_US.UTF-8"

# --- umask -----------------------------------------------------------------
umask 0002

# --- Editor / pager --------------------------------------------------------
if command -v nvim >/dev/null 2>&1; then
  EDITOR="nvim"
else
  EDITOR="vim"
fi
export EDITOR
export VISUAL="$EDITOR"
export PAGER="less"
export LESS="-g -i -M -R -S -w -z-4"

# Colorized man pages via bat, when available.
if command -v bat >/dev/null 2>&1; then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
  export MANROFFOPT="-c"
fi
