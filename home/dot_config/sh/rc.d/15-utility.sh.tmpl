# General utility aliases — shell-agnostic (zsh + bash). The in-use subset of
# prezto's `utility` module; ls/eza aliases live in 10-core.sh.

# sudo shorthand, safer/nicer defaults, quick lookups.
alias _='sudo'
alias mkdir='mkdir -p'
alias diffu='diff --unified'
alias type='type -a'
alias sa='alias | grep -i'                 # `sa foo` → search aliases for foo

# `e`/`p`: launch $EDITOR / $PAGER (functions so args + word-splitting work in
# both shells; e.g. EDITOR="nvim -p").
e() { ${VISUAL:-${EDITOR:-vi}} "$@"; }
p() { ${PAGER:-less} "$@"; }

# grep coloring (BSD uses GREP_COLOR, GNU uses GREP_COLORS).
if command -v grep >/dev/null 2>&1; then
  alias grep='grep --color=auto'
  export GREP_COLOR="${GREP_COLOR:-37;45}"
  export GREP_COLORS="${GREP_COLORS:-mt=37;45}"
fi

# `o` opens files/URLs with the platform opener; pbcopy/pbpaste clipboard bridge.
# The OS branch is resolved by chezmoi at apply time — no runtime `uname` fork.
{{- if eq .chezmoi.os "darwin" }}
alias o='open'                             # pbcopy/pbpaste are native on macOS
{{- else }}
command -v xdg-open >/dev/null 2>&1 && alias o='xdg-open'
if command -v xclip >/dev/null 2>&1; then
  alias pbcopy='xclip -selection clipboard -in'
  alias pbpaste='xclip -selection clipboard -out'
elif command -v xsel >/dev/null 2>&1; then
  alias pbcopy='xsel --clipboard --input'
  alias pbpaste='xsel --clipboard --output'
fi
{{- end }}
alias pbc='pbcopy'
alias pbp='pbpaste'
