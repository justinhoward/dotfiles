# ~/.zprofile — login zsh only. One-time, per-login setup (agents, sockets).
# Interactive UX belongs in ~/.zshrc; always-on env belongs in ~/.zshenv.
{{- if eq .chezmoi.os "darwin" }}

# --- PATH re-assertion (macOS path_helper workaround) ----------------------
# For login shells macOS sources /etc/zprofile *after* ~/.zshenv, and its
# path_helper force-prepends the stock system dirs (/usr/bin, …) to PATH —
# pushing our mise shims and Homebrew bins behind the system tools (e.g. the
# ancient system Ruby 2.6 + its bundler). Cursor/VS Code resolve the GUI
# environment for linters, LSPs, and MCP servers through a login shell, so
# without this those subprocesses pick up /usr/bin/ruby and /usr/bin/bundle.
#
# Re-source the shared env with _PATH_REASSERT so the dirs env.sh manages are
# moved back ahead of the path_helper defaults.
if [ -r "${XDG_CONFIG_HOME:-$HOME/.config}/sh/env.sh" ]; then
  _PATH_REASSERT=1
  . "${XDG_CONFIG_HOME:-$HOME/.config}/sh/env.sh"
  unset _PATH_REASSERT
fi
{{- end }}
