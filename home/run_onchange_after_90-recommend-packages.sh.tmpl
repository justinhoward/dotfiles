#!/usr/bin/env bash
# Runs on `chezmoi apply` whenever this file's contents change (the hash below
# forces a re-run when the tool list changes). Mirrors the old `drecommend`
# behavior: it SUGGESTS installs, it never forces them — matching the
# "installable on a fresh system, but suggests package installs" requirement.
# run_onchange re-runs automatically whenever this rendered script changes.

set -euo pipefail

# Each entry is "binary|package": the binary probed with `command -v`, and the
# package name suggested when it's absent. They differ for a few tools — the
# executable is `rg`/`delta`/`nvim` but the formula is `ripgrep`/`git-delta`/
# `neovim` — so detect on the binary and suggest the installable name.
recommend=(
  "sheldon|sheldon"
  "mise|mise"
  "eza|eza"
  "fzf|fzf"
  "zoxide|zoxide"
  "bat|bat"
  "nvim|neovim"
  "jq|jq"
  "delta|git-delta"
  "rg|ripgrep"       # fzf-lua grep backend
  "fd|fd"            # fzf-lua file backend
  "gh|gh"            # gRb (gh browse) + gh-changelog aliases
)

missing=()
for entry in "${recommend[@]}"; do
  bin="${entry%%|*}"
  pkg="${entry##*|}"
  command -v "$bin" >/dev/null 2>&1 || missing+=("$pkg")
done

if [ "${#missing[@]}" -eq 0 ]; then
  echo "dotfiles: all recommended tools present."
  exit 0
fi

echo "dotfiles: recommended tools not found: ${missing[*]}"
{{- if eq .chezmoi.os "darwin" }}
echo "  install with: brew install ${missing[*]}"
{{- else }}
echo "  install via your package manager, e.g.: <pkg-manager> install ${missing[*]}"
{{- end }}
